<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/button"
        android:padding="16dp">

        <!-- Информация о туре -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Оформление заказа"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tourTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Название тура"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tourDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дата:"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tourPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Цена:"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tourDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Длительность:"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tourSeats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Места:"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tourCountry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Страна:"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp" />

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Форма ввода данных покупателя -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Данные покупателя"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Фамилия -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Фамилия"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/lastNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите фамилию"
            android:background="@android:color/transparent"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:drawablePadding="8dp" />

        <!-- Имя -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Имя"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/firstNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите имя"
            android:background="@android:color/transparent"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:drawablePadding="8dp" />

        <!-- Отчество -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отчество"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/middleNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите отчество "
            android:background="@android:color/transparent"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:drawablePadding="8dp" />

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Отмена"
                android:background="@drawable/button_red"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/confirmButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Оформить"
                android:background="@drawable/button_buy"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>